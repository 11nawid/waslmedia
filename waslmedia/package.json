{
  "name": "nextn",
  "version": "0.2.2",
  "private": true,
  "scripts": {
    "predev": "node -e \"try { require('fs').rmSync('.next', { recursive: true, force: true }); } catch (error) { console.warn('Skipping .next cleanup:', error.code || error.message); }\"",
    "dev": "next dev -p 9002",
    "docker:dev": "node scripts/ensure-docker-deps.mjs && npm run dev",
    "dev:turbopack": "next dev --turbopack -p 9002",
    "genkit:dev": "genkit start -- tsx src/ai/dev.ts",
    "genkit:watch": "genkit start -- tsx --watch src/ai/dev.ts",
    "db:schema": "tsx src/db/run-schema.ts",
    "videos:backfill-assets": "tsx src/db/backfill-video-assets.ts",
    "storage:backfill-refs": "tsx src/db/backfill-storage-refs.ts",
    "worker:video-processing": "tsx src/server/workers/video-processing-worker.ts",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit"
  },
