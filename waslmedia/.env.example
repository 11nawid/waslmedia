# App runtime
APP_ENV_MODE=development
APP_BASE_URL=http://localhost:9002

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=waslmedia_v1

# Auth and security
AUTH_SECRET=change-me-auth-secret
MEDIA_TOKEN_SECRET=change-me-media-token-secret
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Storage / media
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_PUBLIC_URL=http://localhost:9000
STORAGE_USE_SSL=false
MINIO_ROOT_USER=replace-me-minio-user
MINIO_ROOT_PASSWORD=replace-me-minio-password

# Redis
REDIS_URL=redis://127.0.0.1:6379

# Payments / Razorpay
RAZORPAY_KEY_ID=rzp_test_replace_me
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_replace_me
RAZORPAY_KEY_SECRET=replace-me-secret
RAZORPAY_WEBHOOK_SECRET=replace-me-webhook-secret
RAZORPAY_WEBHOOK_URL=http://localhost:9002/api/payments/razorpay/webhook

# Ads configuration
ADS_CURRENCY=INR
ADS_GST_PERCENT=18
ADS_ONE_CAMPAIGN_LIMIT=1
ADS_REVIEW_REQUIRED=true
ADS_HOME_INSERT_INTERVAL=12
ADS_SEARCH_INSERT_INTERVAL=12
ADS_IMPRESSION_MIN_VISIBLE_MS=1200
ADS_IMPRESSION_MIN_VISIBLE_RATIO=0.6
ADS_ALLOWED_PLACEMENTS=home,search

# Email / SMTP
SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Waslmedia
SMTP_REPLY_TO=

# Internal Admin
INTERNAL_ADMIN_BOOTSTRAP_NAME=Internal Admin
INTERNAL_ADMIN_BOOTSTRAP_EMAIL=admin@example.com
INTERNAL_ADMIN_BOOTSTRAP_PASSWORD=change-me-internal-admin-password

# Internal / admin tools (legacy compatibility)
# These are kept during the `/api-docs` -> internal admin migration and can
# mirror the bootstrap values above if older code paths still read them.
API_DOCS_ADMIN_EMAIL=admin@example.com
API_DOCS_ADMIN_PASSWORD=change-me-api-docs-admin-password
API_DOCS_DEVELOPER_PASSWORD=change-me-api-docs-developer-password

# Public client config
NEXT_PUBLIC_APP_BASE_URL=http://localhost:9002
NEXT_PUBLIC_APP_NAME=Waslmedia
NEXT_PUBLIC_APP_DESCRIPTION=Sponsored advertising placements and media publishing on Waslmedia.
NEXT_PUBLIC_PUBLIC_BUSINESS_NAME=Waslmedia
NEXT_PUBLIC_PUBLIC_SUPPORT_EMAIL=support@example.com
NEXT_PUBLIC_PUBLIC_SUPPORT_RESPONSE_TIME=2-3 days
NEXT_PUBLIC_BRAND_LOGO_URL=
NEXT_PUBLIC_DEFAULT_PROFILE_PICTURE_URL=
NEXT_PUBLIC_DEFAULT_BANNER_URL=
NEXT_PUBLIC_DEFAULT_THUMBNAIL_URL=

# Internal / diagnostics allowlist
ALLOWED_AI_BASE_URL_HOSTS=
